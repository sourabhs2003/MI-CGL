rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if userId in ["user1", "user2", "user3", "user4"];
    }
    match /users/{userId}/{document=**} {
      allow read, write: if userId in ["user1", "user2", "user3", "user4"];
    }
  }
}
